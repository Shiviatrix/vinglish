type Vector<T>

foreign function vector_new<T>() returns Vector<T>
foreign function vector_push<T>(v: Vector<T>, item: T) returns Vector<T>
foreign function vector_get<T>(v: Vector<T>, index: number) returns T

function main() returns number
begin
    let v be vector_new<number>()
    let v2 be vector_push<number>(v, 42)
    return vector_get<number>(v2, 0)
end
